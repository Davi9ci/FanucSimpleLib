<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <DUT Name="E_FanucStartMode" Id="{11111111-2222-3333-4444-555555555554}">
    <Declaration><![CDATA[(*
  E_FanucStartMode
  Selects the program start method used by FB_FanucStartProgram.

  RSR  – Robot Start Request.
         UI[9..16] bits are one-hot: one bit per program (programs 1..8).
         Robot acknowledges on UO[11..18] ACK1..ACK8.

  PNS  – Program Number Select.
         UI[9..16] bits carry a binary-encoded program number (1..255).
         PROD_START (UI[18]) is pulsed to trigger execution.
         Robot reports current sequence number on UO[11..18] as SNO1..SNO8.

  The active mode is configured in the FANUC controller (not switchable at runtime
  from the PLC). Set eMode to match the robot's UOP configuration.
*)
TYPE E_FanucStartMode :
(
	RSR := 0,   // Robot Start Request  – one-hot bit, programs 1..8
	PNS := 1    // Program Number Select – binary encoded, programs 1..255
);
END_TYPE
]]></Declaration>
  </DUT>
</TcPlcObject>
