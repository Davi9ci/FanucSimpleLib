<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_FanucStartProgram" Id="{639e9b5b-2378-78fc-0e0b-e22f6bfc1f16}" SpecialFunc="None">
    <Declaration><![CDATA[(*
  FB_FanucStartProgram
  Triggers a FANUC robot program start in either RSR or PNS mode.

  RSR mode (eMode = E_FanucStartMode.RSR):
    nProgram 1..8 maps to a one-hot pulse on Start_Program1..8 (UI[9..16]).
    Duration: 200 ms (FANUC RSR minimum hold time).
    Acknowledgement: stStatus.bProg_StartXACK rising edge sets bAck for one scan.

  PNS mode (eMode = E_FanucStartMode.PNS):
    nProgram 1..255 is binary-encoded across Start_Program1..8 (UI[9..16]).
    PROD_START (UI[18]) is pulsed simultaneously for 200 ms to trigger execution.
    Acknowledgement: stStatus.bPrg_Running rising edge sets bAck for one scan.

  Usage:
    - Call every PLC cycle.
    - Pass the stControl struct that FB_FanucEnable populated (VAR_IN_OUT).
      This FB stamps only the Start_ProgramX / Prod_Start bits; all other bits
      set by FB_FanucEnable are preserved.
    - Wire bReady from FB_FanucEnable.bReady to gate starts.
    - Call FB_FanucControl AFTER this FB so it sees the final stControl state.

  Reset:
    bError latches if nProgram is out of range for the selected mode.
    Set bStart FALSE to reset.
*)
{attribute 'documentation' := 'Starts a FANUC program in RSR mode (nProgram 1..8, one-hot pulse) or PNS mode (nProgram 1..255, binary encoded + PROD_START). 200 ms pulse, gated on bReady. bAck goes TRUE one scan when robot confirms start.'}
FUNCTION_BLOCK FB_FanucStartProgram
VAR_INPUT
  bStart   : BOOL;              // Rising edge: start program nProgram (gated on bReady)
  nProgram : INT;               // Program to start: 1..8 (RSR) or 1..255 (PNS)
  eMode    : E_FanucStartMode;  // RSR or PNS – must match FANUC controller UOP config
  bReady   : BOOL;              // Gate: only start when robot is ready (FB_FanucEnable.bReady)
  stStatus : ST_FanucStatus;    // Live robot status – used for ACK feedback
END_VAR
VAR_IN_OUT
  stControl : ST_FanucControl;  // Modified in-place: Start_ProgramX / Prod_Start bits stamped during pulse
END_VAR
VAR_OUTPUT
  bBusy  : BOOL;                      // TRUE while start pulse is active
  bDone  : BOOL;                      // One scan TRUE when pulse complete
  bAck   : BOOL;                      // One scan TRUE when robot acknowledges the start
  bError : BOOL;                      // TRUE if nProgram is out of range; set bStart FALSE to reset
  eState : E_FanucStartProgramState;  // Current state (diagnostic / HMI)
END_VAR
VAR
  _eState      : E_FanucStartProgramState := E_FanucStartProgramState.Idle;
  rtStart      : R_TRIG;  // Rising-edge detector on bStart AND bReady
  rtAck        : R_TRIG;  // Rising-edge detector for ACK feedback (RSR mode)
  rtPrgRunning : R_TRIG;  // Rising-edge detector for PROGRUN (PNS mode)
  tonPulse     : TON;     // 200 ms start pulse timer
  nActiveProg  : INT;     // Program number latched at trigger (stable during pulse)
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ── Edge detect ───────────────────────────────────────────────────────────────
rtStart(CLK := bStart AND bReady);

// ── State machine ─────────────────────────────────────────────────────────────
CASE _eState OF

  E_FanucStartProgramState.Idle:
    stControl.Start_Program1 := FALSE;
    stControl.Start_Program2 := FALSE;
    stControl.Start_Program3 := FALSE;
    stControl.Start_Program4 := FALSE;
    stControl.Start_Program5 := FALSE;
    stControl.Start_Program6 := FALSE;
    stControl.Start_Program7 := FALSE;
    stControl.Start_Program8 := FALSE;
    stControl.Prod_Start      := FALSE;
    tonPulse(IN := FALSE);
    IF rtStart.Q THEN
      // Validate program number for the selected mode before latching.
      IF (eMode = E_FanucStartMode.RSR AND (nProgram < 1 OR nProgram > 8)) OR
         (eMode = E_FanucStartMode.PNS AND (nProgram < 1 OR nProgram > 255)) THEN
        _eState := E_FanucStartProgramState.Error;
      ELSE
        nActiveProg := nProgram;
        _eState     := E_FanucStartProgramState.Pulsing;
      END_IF
    END_IF

  E_FanucStartProgramState.Pulsing:
    // Assert program start bits for 200 ms, then → Done.
    tonPulse(IN := TRUE, PT := T#200MS);
    CASE eMode OF
      E_FanucStartMode.RSR:
        // One-hot: assert only the bit corresponding to nActiveProg.
        CASE nActiveProg OF
          1: stControl.Start_Program1 := TRUE;
          2: stControl.Start_Program2 := TRUE;
          3: stControl.Start_Program3 := TRUE;
          4: stControl.Start_Program4 := TRUE;
          5: stControl.Start_Program5 := TRUE;
          6: stControl.Start_Program6 := TRUE;
          7: stControl.Start_Program7 := TRUE;
          8: stControl.Start_Program8 := TRUE;
        END_CASE
      E_FanucStartMode.PNS:
        // Binary-encode nActiveProg across PNS1..PNS8 and assert PROD_START.
        stControl.Start_Program1 := (nActiveProg AND   1) <> 0;
        stControl.Start_Program2 := (nActiveProg AND   2) <> 0;
        stControl.Start_Program3 := (nActiveProg AND   4) <> 0;
        stControl.Start_Program4 := (nActiveProg AND   8) <> 0;
        stControl.Start_Program5 := (nActiveProg AND  16) <> 0;
        stControl.Start_Program6 := (nActiveProg AND  32) <> 0;
        stControl.Start_Program7 := (nActiveProg AND  64) <> 0;
        stControl.Start_Program8 := (nActiveProg AND 128) <> 0;
        stControl.Prod_Start      := TRUE;
    END_CASE
    IF tonPulse.Q THEN
      tonPulse(IN := FALSE);
      _eState := E_FanucStartProgramState.Done;
    END_IF

  E_FanucStartProgramState.Done:
    // bDone TRUE for one scan (derived below); clear all bits, then → Idle.
    stControl.Start_Program1 := FALSE;
    stControl.Start_Program2 := FALSE;
    stControl.Start_Program3 := FALSE;
    stControl.Start_Program4 := FALSE;
    stControl.Start_Program5 := FALSE;
    stControl.Start_Program6 := FALSE;
    stControl.Start_Program7 := FALSE;
    stControl.Start_Program8 := FALSE;
    stControl.Prod_Start      := FALSE;
    _eState := E_FanucStartProgramState.Idle;

  E_FanucStartProgramState.Error:
    // Program number out of range for selected mode. Set bStart FALSE to reset.
    stControl.Start_Program1 := FALSE;
    stControl.Start_Program2 := FALSE;
    stControl.Start_Program3 := FALSE;
    stControl.Start_Program4 := FALSE;
    stControl.Start_Program5 := FALSE;
    stControl.Start_Program6 := FALSE;
    stControl.Start_Program7 := FALSE;
    stControl.Start_Program8 := FALSE;
    stControl.Prod_Start      := FALSE;
    IF NOT bStart THEN
      _eState := E_FanucStartProgramState.Idle;
    END_IF

ELSE
  _eState := E_FanucStartProgramState.Error;

END_CASE

// ── ACK detection ─────────────────────────────────────────────────────────────
// RSR: rising edge on the ACK bit matching nActiveProg (UO[11..18])
// PNS: rising edge on PROGRUN (UO[3]) confirms the program started executing
IF eMode = E_FanucStartMode.RSR THEN
  CASE nActiveProg OF
    1: rtAck(CLK := stStatus.bProg_Start1ACK);
    2: rtAck(CLK := stStatus.bProg_Start2ACK);
    3: rtAck(CLK := stStatus.bProg_Start3ACK);
    4: rtAck(CLK := stStatus.bProg_Start4ACK);
    5: rtAck(CLK := stStatus.bProg_Start5ACK);
    6: rtAck(CLK := stStatus.bProg_Start6ACK);
    7: rtAck(CLK := stStatus.bProg_Start7ACK);
    8: rtAck(CLK := stStatus.bProg_Start8ACK);
  ELSE
    rtAck(CLK := FALSE);
  END_CASE
ELSE // PNS
  rtPrgRunning(CLK := stStatus.bPrg_Running);
END_IF

// ── Derived outputs ───────────────────────────────────────────────────────────
eState := _eState;
bBusy  := (_eState = E_FanucStartProgramState.Pulsing);
bDone  := (_eState = E_FanucStartProgramState.Done);
bError := (_eState = E_FanucStartProgramState.Error);
bAck   := SEL(eMode = E_FanucStartMode.RSR, rtPrgRunning.Q, rtAck.Q);


(* Option 2 - without PNS) 
// ── Edge detect ───────────────────────────────────────────────────────────────
rtStart(CLK := bStart AND bReady);

// ── State machine ─────────────────────────────────────────────────────────────
CASE _eState OF

  E_FanucStartProgramState.Idle:
    stControl.Start_Program1 := FALSE;
    stControl.Start_Program2 := FALSE;
    stControl.Start_Program3 := FALSE;
    stControl.Start_Program4 := FALSE;
    stControl.Start_Program5 := FALSE;
    stControl.Start_Program6 := FALSE;
    stControl.Start_Program7 := FALSE;
    stControl.Start_Program8 := FALSE;
    tonPulse(IN := FALSE);
    IF rtStart.Q THEN
      IF nProgram < 1 OR nProgram > 8 THEN
        _eState := E_FanucStartProgramState.Error;
      ELSE
        nActiveProg := nProgram;
        _eState     := E_FanucStartProgramState.Pulsing;
      END_IF
    END_IF

  E_FanucStartProgramState.Pulsing:
    // One-hot: assert only the bit corresponding to nActiveProg for 200 ms.
    tonPulse(IN := TRUE, PT := T#200MS);
    CASE nActiveProg OF
      1: stControl.Start_Program1 := TRUE;
      2: stControl.Start_Program2 := TRUE;
      3: stControl.Start_Program3 := TRUE;
      4: stControl.Start_Program4 := TRUE;
      5: stControl.Start_Program5 := TRUE;
      6: stControl.Start_Program6 := TRUE;
      7: stControl.Start_Program7 := TRUE;
      8: stControl.Start_Program8 := TRUE;
    END_CASE
    IF tonPulse.Q THEN
      tonPulse(IN := FALSE);
      _eState := E_FanucStartProgramState.Done;
    END_IF

  E_FanucStartProgramState.Done:
    stControl.Start_Program1 := FALSE;
    stControl.Start_Program2 := FALSE;
    stControl.Start_Program3 := FALSE;
    stControl.Start_Program4 := FALSE;
    stControl.Start_Program5 := FALSE;
    stControl.Start_Program6 := FALSE;
    stControl.Start_Program7 := FALSE;
    stControl.Start_Program8 := FALSE;
    _eState := E_FanucStartProgramState.Idle;

  E_FanucStartProgramState.Error:
    stControl.Start_Program1 := FALSE;
    stControl.Start_Program2 := FALSE;
    stControl.Start_Program3 := FALSE;
    stControl.Start_Program4 := FALSE;
    stControl.Start_Program5 := FALSE;
    stControl.Start_Program6 := FALSE;
    stControl.Start_Program7 := FALSE;
    stControl.Start_Program8 := FALSE;
    IF NOT bStart THEN
      _eState := E_FanucStartProgramState.Idle;
    END_IF

ELSE
  _eState := E_FanucStartProgramState.Error;

END_CASE

// ── ACK detection ─────────────────────────────────────────────────────────────
CASE nActiveProg OF
  1: rtAck(CLK := stStatus.bProg_Start1ACK);
  2: rtAck(CLK := stStatus.bProg_Start2ACK);
  3: rtAck(CLK := stStatus.bProg_Start3ACK);
  4: rtAck(CLK := stStatus.bProg_Start4ACK);
  5: rtAck(CLK := stStatus.bProg_Start5ACK);
  6: rtAck(CLK := stStatus.bProg_Start6ACK);
  7: rtAck(CLK := stStatus.bProg_Start7ACK);
  8: rtAck(CLK := stStatus.bProg_Start8ACK);
ELSE
  rtAck(CLK := FALSE);
END_CASE

// ── Derived outputs ───────────────────────────────────────────────────────────
eState := _eState;
bBusy  := (_eState = E_FanucStartProgramState.Pulsing);
bDone  := (_eState = E_FanucStartProgramState.Done);
bError := (_eState = E_FanucStartProgramState.Error);
bAck   := rtAck.Q;
*)]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>